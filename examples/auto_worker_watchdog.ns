rng seed_deterministic hex 00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
rng show

model create watchdog_m graph begin
  input 4
  dense d1 in 4 out 6
  relu r1
  dense d2 in 6 out 2
  softmax s1
  chain d1 r1 d2 s1
graph end

ctx create watchdog_ctx model watchdog_m device cpu
chan create watch_in cap 1
worker spawn watchdog_w ctx watchdog_ctx interval_ms 50 priority normal source chan watch_in sink print

sleep 450
stats
worker stopall
