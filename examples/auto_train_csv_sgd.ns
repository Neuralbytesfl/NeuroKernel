rng seed_deterministic hex bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
rng show

model create train_m graph begin
  input 2
  dense d1 in 2 out 8
  relu r1
  dense d2 in 8 out 2
  softmax s1
  chain d1 r1 d2 s1
graph end

model train train_m csv "examples/auto_train_xor.csv" epochs 4000 lr 0.1

ctx create train_ctx model train_m device cpu
ctx run train_ctx input 0,0
ctx run train_ctx input 0,1
ctx run train_ctx input 1,0
ctx run train_ctx input 1,1
